# Telegram Bot Configuration
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ

# Admin User IDs (comma-separated list of Telegram user IDs)
ADMIN_IDS=123456789,987654321

# PostgreSQL Configuration
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=access_manager

# Redis Configuration (DB 3)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=3

# Logging Configuration
LOG_CHAT_ID=-1001234567890
LOG_THREAD_ID=12345
LOG_LEVEL=INFO

# Bot Configuration
DEFAULT_LANG=ru
GRACE_PERIOD_MINUTES=180
COMPLIANCE_SCAN_TIME=03:00
GRACE_WATCHER_INTERVAL_MINUTES=5
HEALTH_PORT=8080
SUPPORT_URL=https://t.me/your_support_bot

# Broadcast (aiogram-broadcast)
BROADCAST_RPS_DELAY=0.05
BROADCAST_MAX_RETRIES=3